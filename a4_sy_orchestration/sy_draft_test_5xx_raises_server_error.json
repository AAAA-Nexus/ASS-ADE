  "body": "def test_5xx_raises_server_error(self) -> None:\n    for code in (500, 502, 503, 504):\n        with pytest.raises(NexusServerError) as exc_info:\n            raise_for_status(code)\n        assert exc_info.value.status_code == code\n",
