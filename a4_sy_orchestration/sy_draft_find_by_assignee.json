  "body": "def find_by_assignee(self, assignee: str) -> List[Task]:\n    \"\"\"Find all tasks assigned to a person.\"\"\"\n    all_tasks = self.manager.list_all_tasks()\n    return [t for t in all_tasks if t.assignee == assignee]\n",
