  "body": "def run(self, ctx: dict) -> dict:\n    cap = ctx.get(\"capability\", \"\")\n    k = int(ctx.get(\"k\", 5))\n    tools = self.discover(cap, k)\n    return {\"tools\": [{\"name\": t.name, \"score\": t.score, \"server\": t.server} for t in tools]}\n",
