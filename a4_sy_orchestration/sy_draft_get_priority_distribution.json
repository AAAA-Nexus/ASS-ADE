  "body": "def get_priority_distribution(self) -> dict:\n    \"\"\"Get count of tasks by priority.\"\"\"\n    all_tasks = self.manager.list_all_tasks()\n    distribution = {p: 0 for p in TaskPriority}\n    for task in all_tasks:\n        distribution[task.priority] += 1\n    return distribution\n",
