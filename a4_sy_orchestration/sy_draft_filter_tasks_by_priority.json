  "body": "def filter_tasks_by_priority(tasks: List[Task], min_priority: TaskPriority) -> List[Task]:\n    \"\"\"Filter tasks by minimum priority (pure function).\"\"\"\n    return [t for t in tasks if t.priority.value >= min_priority.value]\n",
