  "body": "def validate_g23(self, intent: str, impl: str) -> bool:\n    vi = vector_embed(intent)\n    vc = vector_embed(impl)\n    sim = _cosine(vi, vc)\n    distance = max(0.0, 1.0 - sim) * 10.0\n    return distance <= self._g23_threshold\n",
