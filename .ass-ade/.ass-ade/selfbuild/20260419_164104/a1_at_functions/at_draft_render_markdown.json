  "body": "def render_markdown(goal: str, steps: list[str]) -> str:\n    lines = [\"# Draft Plan\", \"\", f\"Goal: {goal}\", \"\"]\n    lines.extend(f\"{index}. {step}\" for index, step in enumerate(steps, start=1))\n    return \"\\n\".join(lines)\n",
