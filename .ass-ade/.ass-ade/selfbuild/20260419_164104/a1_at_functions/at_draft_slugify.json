  "body": "def slugify(text: str) -> str:\n    \"\"\"CamelCase- and punctuation-aware slug: ``TokenBucket`` \u2192 ``token_bucket``.\"\"\"\n    spaced = re.sub(r\"(?<=[a-z0-9])(?=[A-Z])\", \" \", text)\n    out = re.sub(r\"[^a-z0-9]+\", \"_\", spaced.lower()).strip(\"_\")\n    return out or \"component\"\n",
