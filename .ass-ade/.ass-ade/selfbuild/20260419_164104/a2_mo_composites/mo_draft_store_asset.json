  "body": "def store_asset(self, asset: dict) -> str:\n    text = asset.get(\"summary\") or asset.get(\"name\") or str(asset)[:200]\n    meta = {\"kind\": \"asset\", \"asset\": asset}\n    result = store_vector_memory(\n        text=text,\n        namespace=ASSET_NS,\n        metadata=meta,\n        working_dir=self._working_dir,\n    )\n    self._assets += 1\n    return result.id\n",
