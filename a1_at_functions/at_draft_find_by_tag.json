  "body": "def find_by_tag(self, tag: str) -> List[Task]:\n    \"\"\"Find all tasks with a specific tag.\"\"\"\n    all_tasks = self.manager.list_all_tasks()\n    return [t for t in all_tasks if tag in t.tags]\n",
