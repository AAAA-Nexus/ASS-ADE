  "body": "def count_tasks_by_status(tasks: List[Task]) -> dict:\n    \"\"\"Count tasks in each status (pure function).\"\"\"\n    counts = {status: 0 for status in TaskStatus}\n    for task in tasks:\n        counts[task.status] += 1\n    return counts\n",
