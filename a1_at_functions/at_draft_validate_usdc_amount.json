  "body": "def validate_usdc_amount(value: float) -> float:\n    \"\"\"Positive, max 1,000,000 USDC.\"\"\"\n    if value <= 0:\n        raise ValueError(\"USDC amount must be positive.\")\n    if value > MAX_USDC:\n        raise ValueError(f\"USDC amount exceeds maximum ({MAX_USDC:,.0f}).\")\n    return value\n",
