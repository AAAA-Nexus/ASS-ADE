  "body": "    def test_trim(self):\n        c = Conversation(\"system\")\n        for i in range(60):\n            c.add_user(f\"msg {i}\")\n        assert c.count() == 61  # 1 system + 60 user\n        removed = c.trim(max_messages=10)\n        assert removed == 51\n        assert c.count() == 10\n        # System prompt preserved\n        assert c.messages[0].role == \"system\"\n",
