  "body": "    def clear(cls) -> None:\n        for filename in [\n            \"user_profile.json\", \"project_contexts.json\",\n            \"preferences.json\", \"conversation_history.jsonl\",\n        ]:\n            p = _MEMORY_DIR / filename\n            if p.exists():\n                try:\n                    p.unlink()\n                except OSError:\n                    pass\n",
