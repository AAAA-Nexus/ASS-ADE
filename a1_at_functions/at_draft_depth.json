  "body": "    def depth(self, rel_path: str) -> int:\n        \"\"\"Number of undo steps available for a file.\"\"\"\n        snap_dir = self._snapshot_dir(rel_path)\n        if not snap_dir.exists():\n            return 0\n        return len(list(snap_dir.glob(\"*.snapshot\")))\n",
