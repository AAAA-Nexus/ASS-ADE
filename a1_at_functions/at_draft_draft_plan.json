  "body": "def draft_plan(goal: str, max_steps: int = 5) -> list[str]:\n    if not goal.strip():\n        raise ValueError(\"Goal must not be empty.\")\n\n    _, steps = _detect_track(goal)\n    intro = f\"Define success criteria for: {goal.strip()}\"\n    plan = [intro, *steps]\n    return plan[:max_steps]\n",
