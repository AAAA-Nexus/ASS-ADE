  "body": "def tier_prefix_from_id(dep_id: str) -> str | None:\n    \"\"\"Return the two-letter tier prefix from a component id like ``at.parse.foo``.\"\"\"\n    if \".\" not in dep_id:\n        return None\n    prefix = dep_id.split(\".\", 1)[0]\n    return prefix if prefix in _PREFIX_TO_TIER else None\n",
