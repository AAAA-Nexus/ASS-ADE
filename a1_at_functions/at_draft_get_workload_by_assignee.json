  "body": "def get_workload_by_assignee(self) -> dict:\n    \"\"\"Count tasks assigned to each person.\"\"\"\n    all_tasks = self.manager.list_all_tasks()\n    workload = {}\n    for task in all_tasks:\n        if task.assignee:\n            workload[task.assignee] = workload.get(task.assignee, 0) + 1\n    return workload\n",
