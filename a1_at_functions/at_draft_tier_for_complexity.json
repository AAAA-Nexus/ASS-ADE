{
  "body": "def tier_for_complexity(complexity: float) -> ModelTier:\n    \"\"\"Map a complexity score to a model tier.\"\"\"\n    if complexity < 0.3:\n        return ModelTier.FAST\n    elif complexity < 0.6:\n        return ModelTier.STANDARD\n    else:\n        return ModelTier.DEEP\n",
