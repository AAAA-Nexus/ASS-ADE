  "body": "def build_local_certificate(root: Path, version: str | None = None) -> dict[str, Any]:\n    return {\n        \"schema\": \"ASS-ADE-CERT-001\",\n        \"version\": version or \"unknown\",\n        \"digest\": compute_codebase_digest(root),\n        \"signed_by\": None,\n        \"signature\": None,\n        \"valid\": False,\n        \"issuer\": \"atomadic.tech\",\n    }\n",
