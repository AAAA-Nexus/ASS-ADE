  "body": "def is_healthy(self) -> bool:\n    \"\"\"Return True if the session is active and has remaining calls.\"\"\"\n    if not self.is_active:\n        return False\n    try:\n        s = self.status()\n        remaining = s.remaining_calls\n        return remaining is None or remaining > 0\n    except NexusError:\n        return False\n",
