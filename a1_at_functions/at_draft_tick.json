  "body": "def tick(self) -> BatchResult | None:\n    \"\"\"Advance step counter. Returns BatchResult if batch was submitted.\"\"\"\n    self._step_count += 1\n    if self._step_count % self._batch_interval == 0 and self._pending:\n        return self.contribute_batch()\n    return None\n",
