# ASS-ADE environment variables — copy to .env and fill in values

# Primary API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=

# AAAA-Nexus
AAAA_NEXUS_API_KEY=
AAAA_NEXUS_BASE_URL=

# Stripe (Forge marketplace)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# GitHub
GITHUB_TOKEN=

# ASS-ADE settings
ASS_ADE_LOG_LEVEL=INFO
ASS_ADE_PROVIDER=anthropic
ASS_ADE_MODEL=claude-sonnet-4-6
ASS_ADE_MAX_TOKENS=8192

# Auth gate
ASS_ADE_AUTH_GATE_ENABLED=true
ASS_ADE_LICENSE_KEY=

# Discord bot (scripts/atomadic_discord_bot.py)
# Get a token at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Cloudflare (hello.atomadic.tech worker deployment)
CLOUDFLARE_API_TOKEN=
