# ASS-ADE Environment Configuration
# Copy to .env and fill in keys for whichever providers you want to use.
# ASS-ADE autodetects any provider whose key is set — you don't have to
# configure all of them. Even one key makes the system usable.
# Run `ass-ade providers list` to see which ones are active.

# ═══════════════════════════════════════════════════════════════════════
# AAAA-Nexus (optional — for hybrid/premium profile features)
# ═══════════════════════════════════════════════════════════════════════
# AAAA_NEXUS_API_KEY=an_your_key_here

# ═══════════════════════════════════════════════════════════════════════
# FREE LLM PROVIDERS
# Pick any one (or several). All have permanent free tiers.
# Fill in the keys for the ones you sign up for.
# ═══════════════════════════════════════════════════════════════════════

# ─── Groq — fastest free inference (Llama 3.3 70B) ───────────────────
# Sign up: https://console.groq.com
# Free tier: 30 req/min, very fast LPU inference
# GROQ_API_KEY=

# ─── Google Gemini — generous free tier, 1M context ──────────────────
# Sign up: https://aistudio.google.com/apikey
# Free tier: 15 req/min, 1500 req/day
# GEMINI_API_KEY=

# ─── OpenRouter — aggregator with many :free models ──────────────────
# Sign up: https://openrouter.ai/keys
# Free tier: 20 req/min, 200 req/day on :free models
# OPENROUTER_API_KEY=

# ─── Cerebras — wafer-scale inference, extremely fast ────────────────
# Sign up: https://cloud.cerebras.ai
# Free tier: 30 req/min, Llama 3.3 70B
# CEREBRAS_API_KEY=

# ─── Mistral La Plateforme — strong at code & multilingual ───────────
# Sign up: https://console.mistral.ai
# Free experimentation tier
# MISTRAL_API_KEY=

# ─── GitHub Models — free GPT-4o + o1 via GitHub token ───────────────
# Sign up: https://github.com/marketplace/models (use existing GitHub token)
# Rate-limited free access
# GITHUB_TOKEN=

# ─── Hugging Face Inference — huge model selection ───────────────────
# Sign up: https://huggingface.co/settings/tokens
# Free tier shared across models (Llama 3.3 70B, Qwen2.5-Coder 32B)
# HF_TOKEN=

# ─── Together AI — some :free suffix models + starter credit ─────────
# Sign up: https://api.together.xyz/settings/api-keys
# Free: Llama 3.3 70B, DeepSeek R1 Distill
# TOGETHER_API_KEY=

# ─── DeepInfra — pay-per-token with free starter credit ──────────────
# Sign up: https://deepinfra.com/dash/api_keys
# DEEPINFRA_TOKEN=

# ─── Chutes.ai — free DeepSeek V3 + R1 via Bittensor ─────────────────
# Sign up: https://chutes.ai
# Free tier with generous limits, decentralized inference
# CHUTES_API_TOKEN=

# Pollinations AI — no signup required, always available as fallback.
# No env var needed.

# ═══════════════════════════════════════════════════════════════════════
# LOCAL PROVIDERS (no key, no internet — best for offline work)
# ═══════════════════════════════════════════════════════════════════════

# ─── Ollama — local models, no key ───────────────────────────────────
# Install: https://ollama.com/download
# Start:   ollama serve
# Pull:    ollama pull qwen2.5-coder:7b
# OLLAMA_HOST=http://localhost:11434

# ─── LM Studio — GUI for local models ────────────────────────────────
# Install: https://lmstudio.ai
# Start the local server from the UI, then:
# LMSTUDIO_HOST=http://localhost:1234

# ═══════════════════════════════════════════════════════════════════════
# PAID PROVIDERS (optional — bypass the free catalog if you have budget)
# ═══════════════════════════════════════════════════════════════════════

# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# CUSTOM / EXPLICIT PROVIDER (overrides everything above)
# ═══════════════════════════════════════════════════════════════════════
# Point ASS-ADE at any OpenAI-compatible endpoint (vLLM, LocalAI, etc.)
# ASS_ADE_PROVIDER_URL=
# ASS_ADE_PROVIDER_KEY=
# ASS_ADE_MODEL=
